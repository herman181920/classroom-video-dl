# Optional: match a specific Google account during sign-in detection.
# Substring of the email address shown in the Google Account aria-label.
# Leave unset to accept the first signed-in Google account.
USER_EMAIL=

# Optional: where to store the persistent Playwright Chromium profile.
# Default: ~/Library/Caches/course-dl/profile (macOS) or ~/.cache/course-dl/profile (Linux)
COURSE_DL_PROFILE=

# Set to 1 the first time you run auth_profile.cjs / scrape / download
# to open a visible Chromium window for sign-in.
LOGIN=

# How many parallel Drive download workers (download_parallel.cjs only).
N=3
